{
  "name": "knobel-manager-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "prod": "vite --mode production",
    "local": "vite --mode development",
    "api:gen": "openapi-ts",
    "build": "tsc -b && vite build --mode production",
    "check": "tsc --noEmit && biome ci . && i18next-cli status && i18next-cli lint && i18next-cli extract --ci",
    "fix": "biome check --write .",
    "test": "jest",
    "knip": "knip --strict",
    "knip:fix": "knip --strict --fix --format",
    "preview": "vite preview",
    "prepare": "husky",
    "clean": "rm -rf node_modules dist",
    "deploy": "pnpm build && firebase deploy --only hosting"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit'",
      "bash -c 'pnpm exec i18next-cli lint'"
    ],
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "dependencies": {
    "@mantine/core": "^9.1.1",
    "@mantine/form": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/modals": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@tabler/icons-react": "^3.43.0",
    "firebase": "^12.13.0",
    "i18next": "^26.0.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.7",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.15.0",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-typescript": "^7.28.5",
    "@biomejs/biome": "^2.4.14",
    "@hey-api/openapi-ts": "^0.97.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-jest": "^30.4.1",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "husky": "^9.1.7",
    "i18next-cli": "^1.56.11",
    "jest": "^30.4.1",
    "jest-environment-jsdom": "^30.4.1",
    "jest-util": "^30.4.1",
    "knip": "^6.12.1",
    "lint-staged": "^17.0.3",
    "msw": "^2.14.5",
    "postcss": "^8.5.14",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vite-plugin-mkcert": "^2.0.0",
    "web-streams-polyfill": "^4.2.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.3"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.1"
    },
    "onlyBuiltDependencies": [
      "msw"
    ]
  }
}
