{
  "name": "knobel-manager-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=26.0.0 <27.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "prod": "vite --mode production",
    "local": "vite --mode development",
    "api:gen": "rtk-query-codegen-openapi src/store/openapi-config.ts",
    "build": "tsc -b && vite build --mode production",
    "check": "tsc --noEmit && biome ci . && i18next-cli status && i18next-cli lint && i18next-cli extract --ci",
    "fix": "biome check --write .",
    "test": "jest",
    "knip": "knip",
    "knip:fix": "knip --fix --format",
    "preview": "vite preview",
    "prepare": "husky",
    "clean": "rm -rf node_modules dist",
    "deploy": "pnpm build && firebase deploy --only hosting"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bash -c 'tsc --noEmit'",
      "bash -c 'pnpm exec i18next-cli lint'"
    ],
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "dependencies": {
    "@mantine/core": "^9.4.2",
    "@mantine/form": "^9.4.2",
    "@mantine/hooks": "^9.4.2",
    "@mantine/modals": "^9.4.2",
    "@mantine/notifications": "^9.4.2",
    "@reduxjs/toolkit": "^2.12.0",
    "@tabler/icons-react": "^3.45.0",
    "firebase": "^12.16.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "redux": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-typescript": "^8.0.1",
    "@biomejs/biome": "^2.5.5",
    "@rolldown/plugin-babel": "^0.2.3",
    "@rtk-query/codegen-openapi": "^2.2.0",
    "@testing-library/jest-dom": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-jest": "^30.4.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "esbuild": "^0.28.1",
    "esbuild-runner": "^2.2.2",
    "husky": "^9.1.7",
    "i18next-cli": "^1.66.2",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.21",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-mkcert": "^2.1.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  }
}
